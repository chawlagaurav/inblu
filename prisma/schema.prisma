generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model coupons {
  id                  String    @id
  code                String    @unique
  description         String?
  discount_type       String    @default("percentage")
  discount_value      Decimal   @db.Decimal(10, 2)
  min_order_amount    Decimal?  @db.Decimal(10, 2)
  max_discount_amount Decimal?  @db.Decimal(10, 2)
  max_uses            Int?
  used_count          Int       @default(0)
  is_active           Boolean   @default(true)
  start_date          DateTime?
  end_date            DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime
}

model enquiries {
  id          String        @id
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  status      EnquiryStatus @default(NEW_LEAD)
  resolved_at DateTime?
  created_at  DateTime      @default(now())
  updated_at  DateTime
  comment     String?
}

model inventory_transactions {
  id              String           @id
  product_id      String
  type            String
  quantity        Int
  previous_stock  Int
  new_stock       Int
  reference_type  String
  reference_id    String?
  note            String?
  created_at      DateTime         @default(now())
  unit_cost       Decimal?         @db.Decimal(10, 2)
  products        products         @relation(fields: [product_id], references: [id])
  purchase_orders purchase_orders? @relation(fields: [reference_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model marketing_content {
  id         String    @id
  key        String    @unique
  title      String?
  subtitle   String?
  content    String?
  image_url  String?
  link_url   String?
  link_text  String?
  is_active  Boolean   @default(true)
  start_date DateTime?
  end_date   DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model marketing_settings {
  id                  String    @id
  popup_enabled       Boolean   @default(true)
  popup_headline      String    @default("GET 10% OFF YOUR FIRST ORDER")
  popup_subtext       String    @default("Join our community and get exclusive offers on water purification products.")
  discount_code       String    @default("CLEANWATER10")
  discount_percentage Int       @default(10)
  popup_delay         Int       @default(5)
  start_date          DateTime?
  end_date            DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_items {
  id         String   @id
  order_id   String
  product_id String
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  products   products @relation(fields: [product_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  id                    String             @id
  user_id               String?
  customer_name         String
  email                 String
  phone                 String?
  total_amount          Decimal            @db.Decimal(10, 2)
  subtotal              Decimal            @db.Decimal(10, 2)
  gst                   Decimal            @db.Decimal(10, 2)
  shipping_cost         Decimal            @db.Decimal(10, 2)
  discount_amount       Decimal            @default(0) @db.Decimal(10, 2)
  coupon_code           String?
  stripe_payment_intent String?            @unique
  stripe_session_id     String?
  status                OrderStatus        @default(PENDING)
  payment_status        PaymentStatus      @default(PENDING)
  shipping_address      Json
  tracking_number       String?
  notes                 String?
  is_guest              Boolean            @default(false)
  created_at            DateTime           @default(now())
  updated_at            DateTime
  delivered_at          DateTime?
  service_due_date      DateTime?
  order_items           order_items[]
  users                 users?             @relation(fields: [user_id], references: [id])
  service_requests      service_requests[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id                     String                   @id
  name                   String
  description            String
  price                  Decimal                  @db.Decimal(10, 2)
  image_url              String
  images                 String[]                 @default([])
  sku                    String?
  stock                  Int                      @default(0)
  category               String
  specifications         Json?                    @default("{}")
  manual_url             String?
  is_best_seller         Boolean                  @default(false)
  is_active              Boolean                  @default(true)
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  categories             String[]                 @default([])
  service_tenure_months  Int                      @default(6)
  related_product_ids    String[]                 @default([])
  inventory_transactions inventory_transactions[]
  order_items            order_items[]
}

model purchase_orders {
  id                     String                   @id
  po_number              String?
  vendor_name            String?
  file_url               String?
  created_at             DateTime                 @default(now())
  total_cost             Decimal?                 @db.Decimal(10, 2)
  inventory_transactions inventory_transactions[]
}

model service_requests {
  id                String               @id
  ticket_number     String               @unique
  name              String
  email             String
  phone             String
  address           String?
  city              String?
  state             String?
  postcode          String?
  service_type      ServiceType
  product_name      String?
  purchase_date     DateTime?
  issue_description String
  preferred_date    DateTime?
  status            ServiceRequestStatus @default(PENDING)
  priority          String               @default("NORMAL")
  assigned_to       String?
  internal_notes    String?
  resolution        String?
  scheduled_date    DateTime?
  completed_at      DateTime?
  created_at        DateTime             @default(now())
  updated_at        DateTime
  order_id          String
  orders            orders               @relation(fields: [order_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subscribers {
  id         String   @id
  email      String   @unique
  source     String   @default("popup")
  created_at DateTime @default(now())
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model testimonials {
  id            String   @id
  content       String
  rating        Int      @default(5)
  author_name   String
  author_avatar String?
  is_approved   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id         String   @id
  email      String   @unique
  name       String?
  phone      String?
  role       Role     @default(CUSTOMER)
  created_at DateTime @default(now())
  updated_at DateTime
  orders     orders[]
}

enum EnquiryStatus {
  NEW_LEAD
  INTERESTED
  FOLLOW_UP
  NEED_MORE_INFO
  QUOTATION_SENT
  NEGOTIATION
  CONVERTED_TO_ORDER
  NO_RESPONSE
  NOT_INTERESTED
  LOST
  FUTURE_FOLLOW_UP
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ServiceRequestStatus {
  PENDING
  IN_PROGRESS
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ServiceType {
  INSTALLATION
  MAINTENANCE
  REPAIR
  FILTER_REPLACEMENT
  INSPECTION
  WARRANTY_CLAIM
  OTHER
}
